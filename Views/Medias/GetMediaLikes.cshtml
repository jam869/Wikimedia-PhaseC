@model Models.Media

@if (Model != null)
{
    int connectedId = Models.User.ConnectedUser.Id;
    var likes = DAL.DB.Likes.ToList().Where(l => l.MediaId == Model.Id).ToList();
    bool userLiked = likes.Any(l => l.UserId == connectedId);
    string thumbIcon = userLiked ? "fa-solid fa-thumbs-up" : "fa-regular fa-thumbs-up";
    string likedBy = string.Join("\n", likes.Select(l => DAL.DB.Users.Get(l.UserId).Name));

    <div style="color: var(--bs-blue, #0d6efd); font-size: 1.2em; display: inline-flex; align-items: center; gap: 5px;">
        <span title="@likedBy" class="like-count" style="cursor:help; font-weight:bold;">@likes.Count</span>
        <i class="@thumbIcon like-btn" style="cursor: pointer;" onclick="toggleMediaLikeFast(@Model.Id, this)"></i>
    </div>
}